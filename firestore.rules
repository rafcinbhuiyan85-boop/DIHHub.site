rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rafcinbhuiyan85@gmail.com'
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Template Validation
    function isValidTemplate(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.htmlContent is string;
    }

    match /templates/{templateId} {
      allow read, write: if true;
    }
    match /templates/{document=**} {
      allow read, write: if true;
    }
    
    // Simple admin check collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console or service account
    }

    // CloudSync Server Backup and Restore Collections
    match /site/{docId} {
      allow read, write: if true;
    }
    match /site/{document=**} {
      allow read, write: if true;
    }
    match /maintenance/{docId} {
      allow read, write: if true;
    }
    match /maintenance/{document=**} {
      allow read, write: if true;
    }
    match /dih_v3_settings/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_users/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_store/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_logs/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_migrations/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_hostinger/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_smm_services/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_smm_orders/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_smm_deposits/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_smm_providers/{docId} {
      allow read, write: if true;
    }
    match /users/{docId} {
      allow read, write: if true;
    }
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
