rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rafcinbhuiyan85@gmail.com'
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Template Validation
    function isValidTemplate(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.htmlContent is string;
    }

    match /templates/{templateId} {
      allow read: if true; // Public access to templates
      
      allow create: if isValidId(templateId) && 
                      isValidTemplate(request.resource.data) &&
                      request.resource.data.id == templateId;
                      
      allow update: if isValidTemplate(request.resource.data) &&
                      request.resource.data.id == templateId &&
                      request.resource.data.id == resource.data.id;
                      
      allow delete: if true;
    }
    
    // Simple admin check collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console or service account
    }

    // CloudSync Server Backup and Restore Collections
    match /site/{docId} {
      allow read, write: if true;
    }
    match /maintenance/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /dih_v3_settings/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_users/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_store/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_logs/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_migrations/{docId} {
      allow read, write: if true;
    }
    match /dih_v3_hostinger/{docId} {
      allow read, write: if true;
    }
    match /users/{docId} {
      allow read, write: if true;
    }
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
