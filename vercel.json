{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/server.cjs,data/**,firebase-applet-config.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api).+\\.[^/]+)$",
      "destination": "/dist/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/dist/index.html"
    }
  ]
}
